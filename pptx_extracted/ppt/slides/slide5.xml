ect l="0" t="0" r="0" b="0"/></a:stretch></a:blipFill></p:spPr></p:sp><p:sp><p:nvSpPr><p:cNvPr name="TextBox 9" id="9"/><p:cNvSpPr txBox="true"/><p:nvPr/></p:nvSpPr><p:spPr><a:xfrm rot="0"><a:off x="4165998" y="4352460"/><a:ext cx="6247656" cy="2156333"/></a:xfrm><a:prstGeom prst="rect"><a:avLst/></a:prstGeom></p:spPr><p:txBody><a:bodyPr anchor="t" rtlCol="false" tIns="0" lIns="0" bIns="0" rIns="0"><a:spAutoFit/></a:bodyPr><a:lstStyle/><a:p><a:pPr algn="ctr" marL="0" indent="0" lvl="0"><a:lnSpc><a:spcPts val="3483"/></a:lnSpc></a:pPr><a:r><a:rPr lang="en-US" b="true" sz="2177"><a:solidFill><a:srgbClr val="FFFFFF"/></a:solidFill><a:latin typeface="Montserrat Bold"/><a:ea typeface="Montserrat Bold"/><a:cs typeface="Montserrat Bold"/><a:sym typeface="Montserrat Bold"/></a:rPr><a:t>Mặt</a:t></a:r><a:r><a:rPr lang="en-US" b="true" sz="2177" strike="noStrike" u="none"><a:solidFill><a:srgbClr val="FFFFFF"/></a:solidFill><a:latin typeface="Montserrat Bold"/><a:ea typeface="Montserrat Bold"/><a:cs typeface="Montserrat Bold"/><a:sym typeface="Montserrat Bold"/></a:rPr><a:t> đối lập:</a:t></a:r><a:r><a:rPr lang="en-US" b="true" sz="2177" strike="noStrike" u="none"><a:solidFill><a:srgbClr val="FFFFFF"/></a:solidFill><a:latin typeface="Montserrat Medium"/><a:ea typeface="Montserrat Medium"/><a:cs typeface="Montserrat Medium"/><a:sym typeface="Montserrat Medium"/></a:rPr><a:t> là những mặt có xu hướng, tính chất trái ngược nhau nhưng cùng tồn tại khách quan trong mỗi sự vật, hiện tượng của tự nhiên, xã hội và tư duy (Phạm Văn Đức, 2019, p.132)</a:t></a:r></a:p></p:txBody></p:sp><p:sp><p:nvSpPr><p:cNvPr name="Freeform 10" id="10"/><p:cNvSpPr/><p:nvPr/></p:nvSpPr><p:spPr><a:xfrm flipH="false" flipV="false" rot="0"><a:off x="14246049" y="3153303"/><a:ext cx="426386" cy="586280"/></a:xfrm><a:custGeom><a:avLst/><a:gdLst/><a:ahLst/><a:cxnLst/><a:rect r="r" b="b" t="t" l="l"/><a:pathLst><a:path h="586280" w="426386"><a:moveTo><a:pt x="0" y="0"/></a:moveTo><a:lnTo><a:pt x="426385" y="0"/></a:lnTo><a:lnTo><a:pt x="426385" y="586281"/></a:lnTo><a:lnTo><a:pt x="0" y="586281"/></a:lnTo><a:lnTo><a:pt x="0" y="0"/></a:lnTo><a:close/></a:path></a:pathLst></a:custGeom><a:blipFill><a:blip r:embed="rId9"><a:extLst><a:ext uri="{96DAC541-7B7A-43D3-8B79-37D633B846F1}"><asvg:svgBlip r:embed="rId10" xmlns:asvg="http://schemas.microsoft.com/office/drawing/2016/SVG/main"/></a:ext></a:extLst></a:blip><a:stretch><a:fillRect l="0" t="0" r="0" b="0"/></a:stretch></a:blipFill></p:spPr></p:sp><p:sp><p:nvSpPr><p:cNvPr name="TextBox 11" id="11"/><p:cNvSpPr txBox="true"/><p:nvPr/></p:nvSpPr><p:spPr><a:xfrm rot="0"><a:off x="4976996" y="8201525"/><a:ext cx="11609359" cy="1718448"/></a:xfrm><a:prstGeom prst="rect"><a:avLst/></a:prstGeom></p:spPr><p:txBody><a:bodyPr anchor="t" rtlCol="false" tIns="0" lIns="0" bIns="0" rIns="0"><a:spAutoFit/></a:bodyPr><a:lstStyle/><a:p><a:pPr algn="ctr" marL="0" indent="0" lvl="0"><a:lnSpc><a:spcPts val="3483"/></a:lnSpc></a:pPr><a:r><a:rPr lang="en-US" sz="2177"><a:solidFill><a:srgbClr val="FFFFFF"/></a:solidFill><a:latin typeface="Montserrat"/><a:ea typeface="Montserrat"/><a:cs typeface="Montserrat"/><a:sym typeface="Montserrat"/></a:rPr><a:t>Sự</a:t></a:r><a:r><a:rPr lang="en-US" sz="2177" strike="noStrike" u="none"><a:solidFill><a:srgbClr val="FFFFFF"/></a:solidFill><a:latin typeface="Montserrat"/><a:ea typeface="Montserrat"/><a:cs typeface="Montserrat"/><a:sym typeface="Montserrat"/></a:rPr><a:t> thống nhất của các mặt đối lập thể hiện ở việc chúng phụ thuộc lẫn nhau, vừa</a:t></a:r><a:r><a:rPr lang="en-US" sz="2177" strike="noStrike" u="none"><a:solidFill><a:srgbClr val="FFFFFF"/></a:solidFill><a:latin typeface="Montserrat"/><a:ea typeface="Montserrat"/><a:cs typeface="Montserrat"/><a:sym typeface="Montserrat"/></a:rPr><a:t> g</a:t></a:r><a:r><a:rPr lang="en-US" sz="2177" strike="noStrike" u="none"><a:solidFill><a:srgbClr val="FFFFFF"/></a:solidFill><a:latin typeface="Montserrat"/><a:ea typeface="Montserrat"/><a:cs typeface="Montserrat"/><a:sym typeface="Montserrat"/></a:rPr><a:t>iằng co vừa cân bằng tạm thời, đồng thời có những yếu tố chung nhất định. Chính nhờ đó, khi có điều kiện phù hợp, các mặt đối lập có thể chuyển hóa lẫn nhau, tạo ra sự vận động và phát triển của sự vật  (Phạm Văn Đức, 2019, p.132).</a:t></a:r></a:p></p:txBody></p:sp><p:sp><p:nvSpPr><p:cNvPr name="TextBox 12" id="12"/><p:cNvSpPr txBox="true"/><p:nvPr/></p:nvSpPr><p:spPr><a:xfrm rot="0"><a:off x="4454064" y="733461"/><a:ext cx="12605797" cy="1786890"/></a:xfrm><a:prstGeom prst="rect"><a:avLst/></a:prstGeom></p:spPr><p:txBody><a:bodyPr anchor="t" rtlCol="false" tIns="0" lIns="0" bIns="0" rIns="0"><a:spAutoFit/></a:bodyPr><a:lstStyle/><a:p><a:pPr algn="ctr" marL="0" indent="0" lvl="0"><a:lnSpc><a:spcPts val="7080"/></a:lnSpc></a:pPr><a:r><a:rPr lang="en-US" b="true" sz="6000" spc="192"><a:solidFill><a:srgbClr val="FFFFFF"/></a:solidFill><a:latin typeface="Montserrat Heavy"/><a:ea typeface="Montserrat Heavy"/><a:cs typeface="Montserrat Heavy"/><a:sym typeface="Montserrat Heavy"/></a:rPr><a:t>QL thống nhất và đấu tranh giữa các mặt đối lập</a:t></a:r></a:p></p:txBody></p:sp><p:sp><p:nvSpPr><p:cNvPr name="TextBox 13" id="13"/><p:cNvSpPr txBox="true"/><p:nvPr/></p:nvSpPr><p:spPr><a:xfrm rot="0"><a:off x="11676539" y="4393296"/><a:ext cx="6015428" cy="2156333"/></a:xfrm><a:prstGeom prst="rect"><a:avLst/></a:prstGeom></p:spPr><p:txBody><a:bodyPr anchor="t" rtlCol="false" tIns="0" lIns="0" bIns="0" rIns="0"><a:spAutoFit/></a:bodyPr><a:lstStyle/><a:p><a:pPr algn="ctr"><a:lnSpc><a:spcPts val="3483"/></a:lnSpc></a:pPr><a:r><a:rPr lang="en-US" b="true" sz="2177" strike="noStrike" u="none"><a:solidFill><a:srgbClr val="FFFFFF"/></a:solidFill><a:latin typeface="Montserrat Bold"/><a:ea typeface="Montserrat Bold"/><a:cs typeface="Montserrat Bold"/><a:sym typeface="Montserrat Bold"/></a:rPr><a:t>Đấu tranh:</a:t></a:r><a:r><a:rPr lang="en-US" b="true" sz="2177" strike="noStrike" u="none"><a:solidFill><a:srgbClr val="FFFFFF"/></a:solidFill><a:latin typeface="Montserrat Medium"/><a:ea typeface="Montserrat Medium"/><a:cs typeface="Montserrat Medium"/><a:sym typeface="Montserrat Medium"/></a:rPr><a:t> là sự tác động qua lại theo xu hướng bài trừ và phủ định lẫn nhau. </a:t></a:r></a:p><a:p><a:pPr algn="ctr" marL="0" indent="0" lvl="0"><a:lnSpc><a:spcPts val="3483"/></a:lnSpc></a:pPr><a:r><a:rPr lang="en-US" b="true" sz="2177" strike="noStrike" u="none"><a:solidFill><a:srgbClr val="FFFFFF"/></a:solidFill><a:latin typeface="Montserrat Medium"/><a:ea typeface="Montserrat Medium"/><a:cs typeface="Montserrat Medium"/><a:sym typeface="Montserrat Medium"/></a:rPr><a:t>⟶ </a:t></a:r><a:r><a:rPr lang="en-US" b="true" sz="2177" strike="noStrike" u="none"><a:solidFill><a:srgbClr val="FFFFFF"/></a:solidFill><a:latin typeface="Montserrat Medium"/><a:ea typeface="Montserrat Medium"/><a:cs typeface="Montserrat Medium"/><a:sym typeface="Montserrat Medium"/></a:rPr><a:t>V.I. Lênin đã khẳng định sự phát triển thực chất là một cuộc "đấu tranh" giữa các mặt đối lập (Phạm Văn Đức, 2019, p.132).</a:t></a:r></a:p></p:txBody></p:sp></p:spTree></p:cSld><p:clrMapOvr><a:masterClrMapping/></p:clrMapOvr></p:sld>